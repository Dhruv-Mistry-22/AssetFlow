// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  ASSET_MANAGER
  DEPARTMENT_HEAD
  EMPLOYEE
}

enum AssetState {
  Available
  Allocated
  Reserved
  Under_Maintenance
  Lost
  Retired
  Disposed
}

enum AllocationStatus {
  ACTIVE
  RETURNED
  TRANSFERRED
}

enum TransferStatus {
  REQUESTED
  APPROVED
  COMPLETED
  REJECTED
}

enum BookingStatus {
  UPCOMING
  ONGOING
  COMPLETED
  CANCELLED
}

enum MaintenanceStatus {
  PENDING
  APPROVED
  TECHNICIAN_ASSIGNED
  IN_PROGRESS
  RESOLVED
  REJECTED
}

enum AuditItemStatus {
  VERIFIED
  MISSING
  DAMAGED
}

model User {
  id                    String                @id @default(uuid())
  email                 String                @unique
  password              String
  name                  String
  role                  Role                  @default(EMPLOYEE)
  status                String                @default("ACTIVE")
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt

  departmentId          String?
  department            Department?           @relation("EmployeeDepartment", fields: [departmentId], references: [id])
  
  headedDepartment      Department?           @relation("DepartmentHead")

  allocations           Allocation[]          @relation("UserAllocations")
  raisedTransfers       TransferRequest[]     @relation("RaisedTransfers")
  receivedTransfers     TransferRequest[]     @relation("ReceivedTransfers")
  bookings              Booking[]
  raisedMaintenance     MaintenanceRequest[]  @relation("RaisedMaintenance")
  assignedMaintenance   MaintenanceRequest[]  @relation("AssignedMaintenance")
  auditsAssigned        AuditCycle[]          @relation("CycleAuditors")
  activityLogs          ActivityLog[]
  notifications         Notification[]
}

model Department {
  id                    String                @id @default(uuid())
  name                  String                @unique
  status                String                @default("ACTIVE")
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt

  headId                String?               @unique
  head                  User?                 @relation("DepartmentHead", fields: [headId], references: [id])

  parentDepartmentId    String?
  parentDepartment      Department?           @relation("DepartmentHierarchy", fields: [parentDepartmentId], references: [id])
  subDepartments        Department[]          @relation("DepartmentHierarchy")

  employees             User[]                @relation("EmployeeDepartment")
  allocations           Allocation[]          @relation("DepartmentAllocations")
}

model AssetCategory {
  id                    String                @id @default(uuid())
  name                  String                @unique
  customFields          Json?
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt

  assets                Asset[]
}

model Asset {
  id                    String                @id @default(uuid())
  assetTag              String                @unique
  name                  String
  serialNumber          String?               @unique
  acquisitionDate       DateTime
  acquisitionCost       Float
  condition             String                @default("NEW")
  location              String
  photoUrl              String?
  isBookable            Boolean               @default(false)
  status                AssetState            @default(Available)
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt

  categoryId            String
  category              AssetCategory         @relation(fields: [categoryId], references: [id])

  allocations           Allocation[]
  bookings              Booking[]
  maintenanceRequests   MaintenanceRequest[]
  auditItems            AuditItem[]
  stateHistories        AssetStateHistory[]
}

model Allocation {
  id                    String                @id @default(uuid())
  assetId               String
  asset                 Asset                 @relation(fields: [assetId], references: [id])
  
  userId                String?
  user                  User?                 @relation("UserAllocations", fields: [userId], references: [id])

  departmentId          String?
  department            Department?           @relation("DepartmentAllocations", fields: [departmentId], references: [id])

  allocatedAt           DateTime              @default(now())
  expectedReturnDate    DateTime?
  returnedAt            DateTime?
  checkInNotes          String?
  status                AllocationStatus      @default(ACTIVE)

  transferRequests      TransferRequest[]

  @@unique([assetId, status])
}

model TransferRequest {
  id                    String                @id @default(uuid())
  allocationId          String
  allocation            Allocation            @relation(fields: [allocationId], references: [id])

  fromUserId            String
  fromUser              User                  @relation("RaisedTransfers", fields: [fromUserId], references: [id])

  toUserId              String
  toUser                User                  @relation("ReceivedTransfers", fields: [toUserId], references: [id])

  reason                String
  status                TransferStatus        @default(REQUESTED)
  createdAt             DateTime              @default(now())
  resolvedAt            DateTime?
}

model Booking {
  id                    String                @id @default(uuid())
  assetId               String
  asset                 Asset                 @relation(fields: [assetId], references: [id])

  userId                String
  user                  User                  @relation(fields: [userId], references: [id])

  startTime             DateTime
  endTime               DateTime
  status                BookingStatus         @default(UPCOMING)
  createdAt             DateTime              @default(now())

  @@index([assetId, startTime, endTime, status])
}

model MaintenanceRequest {
  id                    String                @id @default(uuid())
  assetId               String
  asset                 Asset                 @relation(fields: [assetId], references: [id])

  raisedById            String
  raisedBy              User                  @relation("RaisedMaintenance", fields: [raisedById], references: [id])

  description           String
  priority              String                @default("MEDIUM")
  photoUrl              String?
  status                MaintenanceStatus     @default(PENDING)
  createdAt             DateTime              @default(now())
  resolvedAt            DateTime?
  resolutionNotes       String?
  cost                  Float?

  technicianId          String?
  technician            User?                 @relation("AssignedMaintenance", fields: [technicianId], references: [id])
}

model AuditCycle {
  id                    String                @id @default(uuid())
  name                  String                @unique
  startDate             DateTime
  endDate               DateTime
  departmentScope       String?
  locationScope         String?
  status                String                @default("OPEN")
  createdAt             DateTime              @default(now())

  auditors              User[]                @relation("CycleAuditors")
  items                 AuditItem[]
}

model AuditItem {
  id                    String                @id @default(uuid())
  auditCycleId          String
  auditCycle            AuditCycle            @relation(fields: [auditCycleId], references: [id])

  assetId               String
  asset                 Asset                 @relation(fields: [assetId], references: [id])

  status                AuditItemStatus?
  auditedAt             DateTime?
  notes                 String?

  @@unique([auditCycleId, assetId])
}

model AssetStateHistory {
  id                    String                @id @default(uuid())
  assetId               String
  asset                 Asset                 @relation(fields: [assetId], references: [id])

  oldState              AssetState?
  newState              AssetState
  changedAt             DateTime              @default(now())
  notes                 String?
}

model ActivityLog {
  id                    String                @id @default(uuid())
  userId                String
  user                  User                  @relation(fields: [userId], references: [id])

  action                String
  entityType            String
  entityId              String
  createdAt             DateTime              @default(now())
}

model Notification {
  id                    String                @id @default(uuid())
  userId                String
  user                  User                  @relation(fields: [userId], references: [id])

  title                 String
  message               String
  type                  String
  isRead                Boolean               @default(false)
  createdAt             DateTime              @default(now())
}
